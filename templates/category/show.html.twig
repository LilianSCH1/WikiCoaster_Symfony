{% extends 'base.html.twig' %}

{% block title %}Catégorie{% endblock %}

{% block body %}
    <h1>Catégorie</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ category.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ category.name }}</td>
            </tr>
            <tr>
                <th>Couleur</th>
                <td>
                    {% set normalizedColor = category.color ? (category.color starts with('#') ? category.color : '#' ~ category.color) : '#d1d5db' %}
                    <span
                        class="color-swatch color-swatch-lg"
                        style="--swatch-color: {{ normalizedColor }}"
                        title="{{ normalizedColor }}"
                        aria-label="Couleur de la catégorie {{ category.name }}"
                    ></span>
                </td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_category_index') }}" class="btn btn-outline btn-sm">Retour à la liste</a>

    <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-accent btn-sm">Modifier</a>

    {{ include('category/_delete_form.html.twig') }}
{% endblock %}
